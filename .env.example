# Copy to `.env` in this folder (Expo loads it automatically).
# Use your PC's LAN IP so the phone can reach the Next dev server — not "localhost".
EXPO_PUBLIC_FIGURES_API_URL=http://192.168.1.10:3000
GOOGLE_API_KEY=your_key_here

# Yandex — «JavaScript API и HTTP Геокодер» (геокодер + маршрутизатор в приложении)
YANDEX_API_KEY=your_geocoder_router_key_uuid

# Отдельный ключ «API поиска по организациям» — только для npm run collect:monuments (search-maps.yandex.ru).
# Без этой строки скрипт не использует YANDEX_API_KEY, чтобы не словить 403 от геокодерного ключа.
YANDEX_ORG_SEARCH_API_KEY=your_organization_search_key_uuid

# Если в кабинете у ключа ограничение по домену — полный Referer (как в настройках), иначе Node-скрипт получит 403.
# YANDEX_GEOSEARCH_REFERER=https://example.com/

# Apify → yandexMonuments.static.json: скопируй выгрузку в src/data/apify_export.json, затем npm run import:apify
# Либо координаты только из URL карточки (без API ключей): npm run convert:all
